# Required: DashScope (Bailian) ASR API key
# Apply at https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY="your_dashscope_api_key"

# Optional: ASR model (default paraformer-v2)
DASHSCOPE_ASR_MODEL="paraformer-v2"

# Required: your no-watermark parser endpoint (BYO)
# Must end with `url=` and accept the original video URL as the query value.
# Self-host a parser, or use a commercial API.
SOCIAL_VIDEO_PARSER_BASE_URL="https://your-parser.example.com/api?url="

# Optional: where to write the Markdown reports
SOCIAL_VIDEO_OUTPUT_DIR="./reports"
